hetzner_token         = "your-hetzner-api-token"
ssh_public_key        = "ssh-ed25519 AAAA... your-key"
server_type           = "cx22"
location              = "nbg1"
user_timezone         = "Europe/Berlin"
deploy_repo           = "git@github.com:your-user/hermes-deploy.git"
hermes_image_tag      = "v2026.6.19"
ollama_api_key        = "your-ollama-api-key"
ollama_model          = "deepseek-v4-flash"
discord_bot_token     = "your-discord-bot-token"
discord_allowed_users = "your-discord-user-id"
profile_discord_tokens = {
  # Add Discord bot tokens for profiles that should have their own bot
  # researcher    = "bot-token-here"
  # cannavacciuolo = "bot-token-here"
}
deploy_public_key     = "ssh-ed25519 AAAA... your-deploy-public-key"
deploy_key            = <<-EOK
-----BEGIN OPENSSH PRIVATE KEY-----
your-deploy-key-here
-----END OPENSSH PRIVATE KEY-----
EOK

r2_access_key_id     = "your-r2-access-key"
r2_secret_access_key = "your-r2-secret-key"

email_accounts = [
  {
    name      = "gmail"
    email     = "you@gmail.com"
    password  = "your-app-password"
    imap_host = "imap.gmail.com"
    default   = true
  },
]
