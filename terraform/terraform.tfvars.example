hetzner_token         = "your-hetzner-api-token"
ssh_public_key        = "ssh-ed25519 AAAA... your-key"
server_type           = "cx22"
location              = "nbg1"
user_timezone         = "Europe/Berlin"
deploy_repo           = "git@github.com:your-user/hermes-deploy.git"
hermes_image_tag      = "v2026.6.19"
ollama_api_key        = "your-ollama-api-key"
ollama_model          = "deepseek-v4-flash"
discord_bot_token     = "your-discord-bot-token"
discord_allowed_users = "your-discord-user-id"
profile_discord_tokens = {
  # Add Discord bot tokens for profiles that should have their own bot
  # researcher     = "bot-token-here"
  # bruno-barbieri = "bot-token-here"
}
deploy_public_key     = "ssh-ed25519 AAAA... your-deploy-public-key"
deploy_key            = <<-EOK
-----BEGIN OPENSSH PRIVATE KEY-----
your-deploy-key-here
-----END OPENSSH PRIVATE KEY-----
EOK

r2_access_key_id     = "your-r2-access-key"
r2_secret_access_key = "your-r2-secret-key"

# Reddit account for Camofox browser login (research/Barbero use). Dedicated
# throwaway account recommended, not a personal one.
reddit_username = "your-reddit-username"
reddit_password = "your-reddit-password"

# Blind (teamblind.com) account for Camofox browser login (research/Barbero
# use). Unlike Reddit, Blind also needs the operator's home-IP tunnel
# active AND Camofox proxied through it — this is IP-reputation blocked at
# the CDN edge (CloudFront), not just an auth wall. See README's Camofox
# section.
blind_username = "your-blind-account-email"
blind_password = "your-blind-password"

# force_restore defaults to false — deliberately not set here. Routine
# `terraform apply` (config/token/script changes) skips the multi-minute R2
# restore, since it's only needed on a genuinely fresh server. To force one
# for a one-off (disaster recovery, suspected local corruption), pass it on
# the CLI instead of setting it here: terraform apply -var="force_restore=true"

email_accounts = [
  {
    name      = "gmail"
    email     = "you@gmail.com"
    password  = "your-app-password"
    imap_host = "imap.gmail.com"
    default   = true
  },
]
